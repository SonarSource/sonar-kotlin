<?xml version="1.0" encoding="UTF-8"?>
<verification-metadata xmlns="https://schema.gradle.org/dependency-verification" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://schema.gradle.org/dependency-verification https://schema.gradle.org/dependency-verification/dependency-verification-1.3.xsd">
   <configuration>
      <verify-metadata>false</verify-metadata>
      <verify-signatures>false</verify-signatures>
      <trusted-artifacts>
         <trust file=".*-javadoc[.]jar" regex="true" reason="https://docs.gradle.org/8.9/userguide/dependency_verification.html#sec:skipping-javadocs"/>
         <trust file=".*-sources[.]jar" regex="true" reason="https://docs.gradle.org/8.9/userguide/dependency_verification.html#sec:skipping-javadocs"/>
         <trust file="gradle-[0-9.]+-src.zip" regex="true" reason="https://docs.gradle.org/8.9/userguide/dependency_verification.html#sec:skipping-javadocs"/>
      </trusted-artifacts>
   </configuration>
</verification-metadata>
